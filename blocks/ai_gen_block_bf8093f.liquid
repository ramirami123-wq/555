{% doc %}
  @prompt
    beneifts table us  vs others check mark is this ✅ 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-benefits-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-benefits-table__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-benefits-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-benefits-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    width: 50%;
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-benefits-table__checkmark-{{ ai_gen_id }} {
    font-size: {{ block.settings.checkmark_size }}px;
    line-height: 1;
  }

  .ai-benefits-table__us-{{ ai_gen_id }} {
    color: {{ block.settings.us_checkmark_color }};
  }

  .ai-benefits-table__others-{{ ai_gen_id }} {
    color: {{ block.settings.others_checkmark_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-benefits-table__header-cell-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.header_font_size }}px * 0.9);
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-benefits-table__cell-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.body_font_size }}px * 0.9);
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-benefits-table__checkmark-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.checkmark_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-benefits-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-benefits-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-benefits-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-benefits-table__table-{{ ai_gen_id }}">
      <thead class="ai-benefits-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.feature_column_label }}</th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.us_column_label }}</th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.others_column_label }}</th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..10) %}
          {% assign feature_key = 'feature_' | append: i %}
          {% assign us_key = 'us_' | append: i %}
          {% assign others_key = 'others_' | append: i %}
          
          {% assign feature = block.settings[feature_key] %}
          {% assign us_value = block.settings[us_key] %}
          {% assign others_value = block.settings[others_key] %}
          
          {% if feature != blank %}
            <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">{{ feature }}</td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if us_value %}
                  <span class="ai-benefits-table__checkmark-{{ ai_gen_id }} ai-benefits-table__us-{{ ai_gen_id }}">✅</span>
                {% else %}
                  <span class="ai-benefits-table__checkmark-{{ ai_gen_id }}" style="color: {{ block.settings.cross_color }};">{{ block.settings.cross_symbol }}</span>
                {% endif %}
              </td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if others_value %}
                  <span class="ai-benefits-table__checkmark-{{ ai_gen_id }} ai-benefits-table__others-{{ ai_gen_id }}">✅</span>
                {% else %}
                  <span class="ai-benefits-table__checkmark-{{ ai_gen_id }}" style="color: {{ block.settings.cross_color }};">{{ block.settings.cross_symbol }}</span>
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

