{% doc %}
  @prompt
    benefits table
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-benefits-table__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    overflow: hidden;
  }

  .ai-benefits-table__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-benefits-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.row_border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    vertical-align: middle;
  }

  .ai-benefits-table__icon-cell-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    text-align: center;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-benefits-table__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-benefits-table__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-benefits-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-benefits-table__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<benefits-table-{{ ai_gen_id }} class="ai-benefits-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-table__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-benefits-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <table class="ai-benefits-table__table-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign benefit_text_key = 'benefit_' | append: i | append: '_text'
          assign benefit_icon_key = 'benefit_' | append: i | append: '_icon'
          assign benefit_text = block.settings[benefit_text_key]
          assign benefit_icon = block.settings[benefit_icon_key]
        %}

        {% if benefit_text != blank %}
          <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
            <td class="ai-benefits-table__cell-{{ ai_gen_id }} ai-benefits-table__icon-cell-{{ ai_gen_id }}">
              <div class="ai-benefits-table__icon-{{ ai_gen_id }}">
                {% case benefit_icon %}
                  {% when 'check' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  {% when 'star' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% when 'heart' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                  {% when 'shield' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                  {% when 'truck' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                  {% when 'gift' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 12 20 22 4 22 4 12"></polyline>
                      <rect x="2" y="7" width="20" height="5"></rect>
                      <line x1="12" y1="22" x2="12" y2="7"></line>
                      <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                      <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                    </svg>
                  {% when 'leaf' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                    </svg>
                  {% when 'award' %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="8" r="7"></circle>
                      <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                    </svg>
                {% endcase %}
              </div>
            </td>
            <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
              <p class="ai-benefits-table__text-{{ ai_gen_id }}">{{ benefit_text }}</p>
            </td>
          </tr>
        {% endif %}
      {% endfor %}
    </table>
  </div>
</benefits-table-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('benefits-table-{{ ai_gen_id }}', BenefitsTable{{ ai_gen_id }});
  })();
</script>

